# Copy to .env and fill in values before running tests.
# All portal/utility addresses are stable for cartesi CLI local devnets.

# ── Required: set these from `cartesi run` output ──────────────────────────────
CARTESI_APP_ADDRESS=

# ── Required: set these from `forge script Deploy.s.sol` output ───────────────
TEST_ERC20_ADDRESS=
TEST_ERC721_ADDRESS=
TEST_ERC1155_ADDRESS=
MINTABLE_ERC721_ADDRESS=
DELEGATE_VOUCHER_LOGIC_ADDRESS=

# ── Optional: override if using a non-default setup ───────────────────────────
# cartesi run proxies everything through http://127.0.0.1:6751:
#   Anvil RPC  → http://127.0.0.1:6751/anvil
#   Node RPC   → http://127.0.0.1:6751/rpc
#   Inspect    → http://127.0.0.1:6751/inspect/<dapp-name>
RPC_URL=http://127.0.0.1:6751/anvil
NODE_RPC_URL=http://127.0.0.1:6751/rpc
INSPECT_URL=http://127.0.0.1:6751/inspect/tester
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Second Anvil account — used to assert targeted delegate vouchers revert for non-allowed executors
OTHER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# ── Voucher execution tests (suite 08) ─────────────────────────────────────────
# Run cartesi with a short epoch so proofs are available quickly:
#   cartesi run --epoch-length 5
# Then set EPOCH_LENGTH to match:
EPOCH_LENGTH=5

# ── Stable cartesi CLI devnet addresses (do not change) ───────────────────────
INPUT_BOX_ADDRESS=0x1b51e2992A2755Ba4D6F7094032DF91991a0Cfac
ETH_PORTAL_ADDRESS=0xA632c5c05812c6a6149B7af5C56117d1D2603828
ERC20_PORTAL_ADDRESS=0xACA6586A0Cf05bD831f2501E7B4aea550dA6562D
ERC721_PORTAL_ADDRESS=0x9E8851dadb2b77103928518846c4678d48b5e371
ERC1155_SINGLE_PORTAL=0x18558398Dd1a8cE20956287a4Da7B76aE7A96662
ERC1155_BATCH_PORTAL=0xe246Abb974B307490d9C6932F48EbE79de72338A
